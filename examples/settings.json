{
  "// Claude Code settings.json example": "Add these to ~/.claude/settings.json",
  "// Adjust paths to match your Cortex installation": "",
  "// Export CORTEX_WORKER_API_KEY in the shell that launches Claude Code": "The hooks read it from the environment.",

  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/cortex/hooks/session_start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/cortex/hooks/user_prompt_submit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/cortex/hooks/post_tool_use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/cortex/hooks/session_end.sh"
          }
        ]
      }
    ]
  },

  "mcpServers": {
    "cortex-memory": {
      "command": "python3",
      "args": ["/path/to/cortex/src/mcp_memory_server.py"],
      "env": {
        "CORTEX_DATA_DIR": "/path/to/.cortex/data"
      }
    }
  }
}
