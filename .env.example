# ============================================================================
# llm-cortex — Environment Variable Reference
# ============================================================================
# Copy this file to .env.local (in ~/clawd/) and fill in your values.
# The MCP server loads ~/clawd/.env.local at startup via _load_env().
# All variables are optional unless marked REQUIRED.
#
# Generated by Pass R of the adversarial improvement loop (2026-04-16).
# ============================================================================

# ----------------------------------------------------------------------------
# Data Paths
# ----------------------------------------------------------------------------

# Root directory for all Cortex runtime data (vector DB, credentials DB, etc.)
# Canonical default shared by: memory_worker, memory_retriever,
#   credential_manager, unified_vector_store.
# NOTE: src/air/config.py previously defaulted to ~/clawd/data — fixed in
#   Pass R to use this canonical path. Override only if migrating data.
CORTEX_DATA_DIR=~/.cortex/data

# Workspace root for flat-file memory (working-memory/, .planning/,
#   knowledge-graph.json). Used by: context_loader, working_memory,
#   hybrid_search, query_knowledge_graph.
# DEFAULT ~/cortex/ DOES NOT EXIST on a fresh install. Set this explicitly
#   or the scripts will silently create ~/cortex/ on first run.
CORTEX_WORKSPACE=~/cortex

# Override path to a specific cortex-observations.db.
# Defaults to $CORTEX_DATA_DIR/cortex-observations.db.
# Used only by AIR (src/air/config.py) — all other modules derive path from
# CORTEX_DATA_DIR directly.
# CORTEX_DB_PATH=~/.cortex/data/cortex-observations.db

# Override path to the knowledge-graph JSON file.
# Defaults to $CORTEX_WORKSPACE/.planning/knowledge-graph.json
# CORTEX_GRAPH_FILE=~/cortex/.planning/knowledge-graph.json

# Path to an .env file that contains OPENAI_API_KEY (alternative to setting
# the key directly in environment). Used by unified_vector_store when
# CORTEX_EMBEDDING_PROVIDER=openai.
# CORTEX_ENV_FILE=~/clawd/.env.local

# ----------------------------------------------------------------------------
# Memory Worker
# ----------------------------------------------------------------------------

# URL of the cortex memory worker HTTP API.
# Default matches the hardcoded worker port (37778).
CORTEX_WORKER_URL=http://localhost:37778

# API key for authenticating requests to the memory worker.
# Resolution order (memory_worker.py + context_loader.py):
#   1. This env var (if set and non-empty)
#   2. ~/.cortex/data/.worker_api_key  (generated on first start)
#   3. Fresh random key generated at startup (logged as WARNING)
# Pass Z is wiring the key-file mechanism — this var supersedes the generated
# key when set. Leave unset on fresh installs; the worker generates a key
# automatically and writes it to ~/.cortex/data/.worker_api_key.
# CORTEX_WORKER_API_KEY=your-secret-key-here

# ----------------------------------------------------------------------------
# Subscription / Tier
# ----------------------------------------------------------------------------

# Default subscription tier for new observations submitted to the worker.
# Valid values match SubscriptionTier enum in src/subscription.py.
# Example: free, claude_pro, claude_max5, claude_max20, claude_codemax
CORTEX_SUBSCRIPTION_TIER=claude_codemax

# Server-side ceiling: clients claiming a tier higher than this are clamped
# down silently. Useful for restricting shared / multi-tenant deployments.
# Defaults to claude_codemax (Cameron's top paid tier).
CORTEX_SERVER_TIER_CAP=claude_codemax

# Active tier for MCP feature gating (controls which tools are exposed).
# Falls back to CORTEX_SERVER_TIER_CAP, then claude_codemax.
# Set this when running the MCP server at a tier lower than the server cap.
# CORTEX_CURRENT_TIER=claude_codemax

# ----------------------------------------------------------------------------
# Embeddings
# ----------------------------------------------------------------------------

# Embedding backend for unified_vector_store and backfill scripts.
# "local"  — sentence-transformers/all-MiniLM-L6-v2 (384 dims, free, default)
# "openai" — text-embedding-3-small (1536 dims, requires OPENAI_API_KEY)
CORTEX_EMBEDDING_PROVIDER=local

# OpenAI API key. Required only when CORTEX_EMBEDDING_PROVIDER=openai.
# OPENAI_API_KEY=sk-...

# ----------------------------------------------------------------------------
# Features / NER
# ----------------------------------------------------------------------------

# Enable Named Entity Recognition in the memory worker pipeline.
# Set to "false" to disable NER and skip knowledge-graph extraction.
CORTEX_NER_ENABLED=true

# ----------------------------------------------------------------------------
# Agent Identity
# ----------------------------------------------------------------------------

# Name of the agent submitting memories. Used to tag observations so they
# can be filtered by agent in search results.
# Defaults: "main" in mcp_memory_server (stdio), "codex" in
#   mcp_memory_server_sse (HTTP/shared daemon). Override per-process.
# CORTEX_AGENT_NAME=main

# Override the current working directory used to detect project name for
# context_loader cortex recall. Defaults to os.getcwd() at runtime.
# CORTEX_PROJECT_DIR=/Users/cameronbennion/Projects/my-project

# ----------------------------------------------------------------------------
# AIR — Adaptive Inference Routing (proprietary, patent-pending)
# ----------------------------------------------------------------------------

# Classifier backend: "local" (no API key needed) or "api" (Anthropic Claude).
AIR_CLASSIFIER_MODE=local

# Anthropic API key. Required only when AIR_CLASSIFIER_MODE=api.
# ANTHROPIC_API_KEY=sk-ant-...

# Path to AIR's routing-rules SQLite DB.
# Defaults to $CORTEX_DATA_DIR/air_routes.db.
# AIR_DB_PATH=~/.cortex/data/air_routes.db

# Confidence tuning (0.0–1.0 floats).
# AIR_CONFIDENCE_INIT=0.5
# AIR_CONFIDENCE_REWARD=0.1
# AIR_CONFIDENCE_PENALTY=0.2
# AIR_CONFIDENCE_DECAY_RATE=0.95

# Lifecycle thresholds.
# AIR_PRUNE_THRESHOLD=0.2
# AIR_INJECT_THRESHOLD_HIGH=0.7
# AIR_INJECT_THRESHOLD_LOW=0.5

# Cold-start guard: suppress routing until this many cycles have been observed.
# AIR_COLD_START_CYCLES=10

# Cross-project routing threshold.
# AIR_CROSS_PROJECT_THRESHOLD=0.9

# ----------------------------------------------------------------------------
# Storage VPS — conversation-memory MCP
# (clawd/mcp-servers/conversation-memory/config.py)
# ----------------------------------------------------------------------------
# These are only needed if you run the conversation-memory MCP server
# which performs Discord author lookups via SSH to the Storage VPS.

# STORAGE_VPS_SSH_HOST=104.237.203.117
# STORAGE_VPS_SSH_PORT=47822
# STORAGE_VPS_SSH_USER=Administrator
# STORAGE_VPS_DB_NAME=rag_memory
# STORAGE_VPS_DB_USER=postgres
# STORAGE_VPS_PSQL_PATH=C:\Program Files\PostgreSQL\17\bin\psql.exe

# ----------------------------------------------------------------------------
# Trading Data Backfill — scripts/smart_backfill.py only
# These are NOT used by the core memory system.
# ----------------------------------------------------------------------------

# NT8_HOST=100.107.193.101
# NT8_PORT=49999

# POSTGRES_HOST=100.67.112.3
# POSTGRES_PORT=5432
# POSTGRES_DB=tradingcore
# POSTGRES_USER=trading_user
# POSTGRES_PASSWORD=
